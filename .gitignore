# Neuromorphic FPGA Orchestration - Git Ignore Configuration
# This file follows best practices for Go, Rust, Kubernetes, and WASM development

###########################################
# 1. DEVELOPMENT TOOLS & IDE
###########################################

# Claude Code (AI assistant workspace - contains conversation history, not project code)
.claude/
CLAUDE.md

# Publication drafts (private, not for version control)
publication_proposal.md

# VSCode
.vscode/
*.code-workspace

# JetBrains IDEs (GoLand, IntelliJ IDEA, RustRover)
.idea/
*.iml
*.ipr
*.iws
.idea_modules/

# Vim
*.swp
*.swo
*~
.vim/

# Emacs
*~
\#*\#
.\#*

# Sublime Text
*.sublime-project
*.sublime-workspace

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Linux
*~
.directory
.Trash-*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/


###########################################
# 2. GO (Device Plugin)
###########################################

# Binaries
device-plugin/bin/
device-plugin/fpga-device-plugin
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binaries
*.test
*.out

# Go build cache
device-plugin/.cache/

# Go workspace file (Go 1.18+)
go.work
go.work.sum

# Dependency directories
vendor/

# Go coverage files
coverage.txt
coverage.html
*.coverprofile

# Delve debugger
__debug_bin


###########################################
# 3. RUST (WASI Extensions & WASM Workloads)
###########################################

# Build artifacts
wasi-fpga/target/
workloads/wasm/*/target/
**/target/debug/
**/target/release/

# Cargo.lock (should be committed for binaries, but not libraries)
# For this project: device plugin is binary (commit), WASI extension is library (ignore)
wasi-fpga/Cargo.lock

# Backup files generated by rustfmt
**/*.rs.bk

# WASM build artifacts (intermediate)
**/*.wasm
**/*.wasm.map

# Optimized WASM binaries (generated from source, can be rebuilt)
workloads/wasm/**/app.wasm
workloads/wasm/**/app.opt.wasm


###########################################
# 4. CONTAINER IMAGES & BUILD ARTIFACTS
###########################################

# Podman/Buildah local storage (if building locally)
.local-registry/
image-cache/

# OCI image tarballs
*.tar
*.tar.gz
*.oci

# Buildah/Podman build contexts
buildah-*/
podman-*/


###########################################
# 5. KUBERNETES & HELM
###########################################

# Helm generated files
deployments/helm/**/charts/
deployments/helm/**/Chart.lock
deployments/helm/**/*.tgz

# Kubernetes local config (if testing locally)
kubeconfig
kubeconfig.*
*.kubeconfig

# K3s data directory (if running locally)
/var/lib/rancher/

# Kustomize generated files
kustomization.yaml.bak


###########################################
# 6. SECRETS & SENSITIVE DATA
###########################################

# Kubernetes secrets (NEVER commit secrets!)
*secret*.yaml
*-secret.yaml

# Environment files with credentials
.env
.env.*
!.env.example
!.env.template

# TLS certificates and keys (unless explicitly needed for testing)
*.pem
*.key
*.crt
*.p12
*.pfx

# SSH keys
id_rsa
id_dsa
id_ed25519

# Credentials and tokens
credentials.json
token
*.token
auth.json


###########################################
# 7. LOGS & TEMPORARY FILES
###########################################

# Log files
*.log
logs/
*.log.*

# Temporary files
tmp/
temp/
*.tmp
*.temp

# PID files
*.pid


###########################################
# 8. TESTING & CI/CD
###########################################

# Test reports
test-results/
test-reports/
coverage/
htmlcov/

# Benchmark results
benchmarks/
*.bench

# CI/CD generated artifacts (GitLab CI, GitHub Actions)
.gitlab-ci-local/
.github-actions-local/


###########################################
# 9. HARDWARE-SPECIFIC (FPGA)
###########################################

# FPGA bitstreams (large binary files, store in LFS or artifact registry)
*.bit
*.bin
*.xclbin

# XRT generated files (runtime artifacts)
xrt.ini.bak
sdaccel_profile_summary.*
timeline_kernels.csv

# Vivado/Vitis project files (if included in future)
*.jou
*.str
*.log
vivado*.backup*


###########################################
# 10. DOCUMENTATION (Generated)
###########################################

# Generated documentation (keep source, ignore built artifacts)
docs/_build/
docs/.doctrees/
site/

# Doxygen output
doxygen/html/
doxygen/latex/


###########################################
# 11. NODE_MODULES (if using any JS tooling)
###########################################

node_modules/
package-lock.json
yarn.lock


###########################################
# 12. PYTHON (if using any Python scripts)
###########################################

__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.venv/
venv/
ENV/


